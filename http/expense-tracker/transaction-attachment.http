### Upload attachment (receipt/invoice) to a transaction
# Supported types: PDF, JPEG, PNG, WEBP, HEIC
POST {{host}}/api/transaction/{{tracker_id}}/{{transaction_id}}/attachments
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="file"; filename="receipt.pdf"
Content-Type: application/pdf

< ./receipt.pdf
--boundary--

> {%
    client.assert(response.status === 201, "Upload failed");
    client.global.set("attachment_id", response.body.id);
%}

### List attachments on a transaction
GET {{host}}/api/transaction/{{tracker_id}}/{{transaction_id}}/attachments
Authorization: Bearer {{auth_token}}

### Delete an attachment
DELETE {{host}}/api/transaction/{{tracker_id}}/{{transaction_id}}/attachments/{{attachment_id}}
Authorization: Bearer {{auth_token}}